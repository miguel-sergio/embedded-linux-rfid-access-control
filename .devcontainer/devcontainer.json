{
  "name": "Buildroot Build Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "mounts": [
    "source=${localWorkspaceFolder}/../dl,target=/dl,type=bind,consistency=cached",
    "source=rfid-buildroot,target=/workspace/buildroot,type=volume"
  ],
  "remoteEnv": {
    "BR2_DL_DIR": "/dl",
    "BR2_EXTERNAL": "/workspace"
  },
  "postCreateCommand": "if [ ! -f /workspace/buildroot/Makefile ]; then git -C /workspace submodule update --init; fi && sudo chown -R buildroot-user:buildroot-user /workspace/buildroot",
  "remoteUser": "buildroot-user",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
